# Copy this file to `.env` and fill in real secrets before `docker compose up`.
# NEVER commit the filled-in .env (it is gitignored).

# JWT signing secret. HS384 needs a long, random value — at least 48 chars.
# Generate one with:  openssl rand -base64 48
ERP_JWT_SECRET=

# Initial admin account, created once on first boot if it does not exist.
ERP_ADMIN_USERNAME=admin
ERP_ADMIN_PASSWORD=

# Postgres password for the `erp` database user.
ERP_DB_PASSWORD=

# Comma-separated browser origins allowed to call the API. With the bundled
# nginx (frontend + API on one origin) this only matters if you also expose the
# backend directly. Set it to your real site URL, e.g. https://erp.example.com
ERP_CORS_ORIGINS=https://localhost

# --- HTTPS (Caddy) ---
# Public domain -> automatic Let's Encrypt cert. "https://localhost" -> self-signed.
# See Caddyfile for the internal-IP (:443 + tls internal) option.
SITE_ADDRESS=https://localhost

# --- Postgres backups (db-backup service) ---
# Cron-style or shortcut schedule (@daily, @hourly, or "0 3 * * *").
BACKUP_SCHEDULE=@daily
# Retention. Dumps land in ./backups on the host (contains PII — keep it secure).
BACKUP_KEEP_DAYS=14
BACKUP_KEEP_WEEKS=8
BACKUP_KEEP_MONTHS=6
